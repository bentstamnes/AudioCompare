        self._perf_log_dir = os.path.join(_HERE, "logs")

        # ── Prefs ──────────────────────────────────────────────────────────────
        self._prefs: dict = {}
        self._load_prefs()
        self._vol_value       = self._prefs.get("volume", 100)
        self._muted           = self._prefs.get("muted", False)
        self._meter_enabled    = self._prefs.get("meter_enabled", True)
        self._corr_enabled     = self._prefs.get("corr_enabled", False)
        self._lufs_enabled     = self._prefs.get("lufs_enabled", False)
        self._spectrum_enabled    = self._prefs.get("spectrum_enabled", True)
        self._spectrogram_enabled    = self._prefs.get("spectrogram_enabled", False)
        # Fullscreen is never restored from prefs — it requires live DPG items to build.
        # _spectrogram_fullscreen stays False; user re-enables after startup.
        self._spectrogram_fullscreen = False
        # Mutual exclusion: if both were somehow saved as True, prefer spectrum
        if self._spectrum_enabled and self._spectrogram_enabled:
            self._spectrogram_enabled = False
        self._fft_size        = self._prefs.get("fft_size", _FFT_SIZE_DEFAULT)
        self._fft_bands       = self._prefs.get("fft_bands", _FFT_BANDS_DEFAULT)
        self._fft_show_active = self._prefs.get("fft_show_active", True)
        self._wave_normalize  = self._prefs.get("wave_normalize", False)
        self._audio_normalize = self._prefs.get("audio_normalize", False)

        configure_fft(self._fft_size, self._fft_bands)

        # ── Audio engine ───────────────────────────────────────────────────────
        startup_device = None
