                dpg.add_theme_color(dpg.mvThemeCol_Button,        _BAR_BG)
                dpg.add_theme_color(dpg.mvThemeCol_ButtonHovered, (42, 42, 42, 255))
                dpg.add_theme_color(dpg.mvThemeCol_ButtonActive,  (60, 60, 60, 255))
                dpg.add_theme_color(dpg.mvThemeCol_Header,        (50, 50, 50, 255))
                dpg.add_theme_color(dpg.mvThemeCol_HeaderHovered, (60, 60, 60, 255))
                dpg.add_theme_color(dpg.mvThemeCol_FrameBg,       (30, 30, 30, 255))
                dpg.add_theme_color(dpg.mvThemeCol_FrameBgHovered,(40, 40, 40, 255))
                dpg.add_theme_color(dpg.mvThemeCol_SliderGrab,    (180, 180, 180, 255))
                dpg.add_theme_color(dpg.mvThemeCol_SliderGrabActive, _WHITE)
                dpg.add_theme_color(dpg.mvThemeCol_MenuBarBg,     _BAR_BG)
                dpg.add_theme_color(dpg.mvThemeCol_ScrollbarBg,   _BG)
                dpg.add_theme_color(dpg.mvThemeCol_Border,        (40, 40, 40, 255))
                dpg.add_theme_style(dpg.mvStyleVar_WindowRounding,    0)
                dpg.add_theme_style(dpg.mvStyleVar_ChildRounding,     0)
                dpg.add_theme_style(dpg.mvStyleVar_FrameRounding,     2)
                dpg.add_theme_style(dpg.mvStyleVar_WindowPadding,     4, 4)
                dpg.add_theme_style(dpg.mvStyleVar_ItemSpacing,       6, 0)
                dpg.add_theme_style(dpg.mvStyleVar_WindowBorderSize,  0)
                dpg.add_theme_style(dpg.mvStyleVar_ChildBorderSize,   0)
        dpg.bind_theme(global_theme)

        # Primary font: Consolas 13px (matches the original MixABTest look/size).
        # Consolas does not include geometric shapes (▶ ⏸) or emoji (🔇 🔊).
        # Segoe UI Symbol is loaded separately for the play button (▶ ⏸).
        # Segoe UI Emoji is loaded separately for the mute button (🔇 🔊).
        import os as _os
        _FONT_PATH   = r"C:\Windows\Fonts\consola.ttf"
        _FONT_BOLD   = r"C:\Windows\Fonts\consolab.ttf"
        _FONT_SYMBOL = r"C:\Windows\Fonts\seguisym.ttf"
        _FONT_EMOJI  = r"C:\Windows\Fonts\seguiemj.ttf"
        self._font_bold   = None
        self._font_symbol = None
        self._font_emoji  = None
        if _os.path.isfile(_FONT_PATH):
            with dpg.font_registry():
                with dpg.font(_FONT_PATH, 13) as _fnt:
                    dpg.add_font_range_hint(dpg.mvFontRangeHint_Default)
                if _os.path.isfile(_FONT_BOLD):
                    with dpg.font(_FONT_BOLD, 13) as _fnt_bold:
                        dpg.add_font_range_hint(dpg.mvFontRangeHint_Default)
                    self._font_bold = _fnt_bold
                if _os.path.isfile(_FONT_SYMBOL):
                    with dpg.font(_FONT_SYMBOL, 15) as _fnt_symbol:
                        dpg.add_font_range_hint(dpg.mvFontRangeHint_Default)
                        dpg.add_font_range(0x25A0, 0x25FF)  # geometric shapes (▶ ●)
                        dpg.add_font_range(0x2300, 0x23FF)  # misc technical (⏸ Ø)
                    self._font_symbol = _fnt_symbol
                if _os.path.isfile(_FONT_EMOJI):
                    with dpg.font(_FONT_EMOJI, 15) as _fnt_emoji:
                        dpg.add_font_range(0x1F300, 0x1F5FF)  # emoji (🔇 🔊)
                    self._font_emoji = _fnt_emoji
            dpg.bind_font(_fnt)

        # Zero-padding theme for slot child windows — so drawlists start at (0,0)
        with dpg.theme() as self._slot_theme:
            with dpg.theme_component(dpg.mvChildWindow):
                dpg.add_theme_style(dpg.mvStyleVar_WindowPadding, 0, 0)
                dpg.add_theme_style(dpg.mvStyleVar_ItemSpacing,   0, 0)

    # ── UI construction ───────────────────────────────────────────────────────

    def _build_ui(self) -> None:
        # Use configured viewport dimensions as initial estimate.
        # get_viewport_client_width/height() returns screen size before show_viewport(),
        # so we use get_viewport_width/height() (the configured size) instead.
        vw = dpg.get_viewport_width()
        vh = dpg.get_viewport_height()
        # Subtract typical OS title bar / frame thickness for initial estimate
        vw = max(1, vw - 16)
        vh = max(1, vh - 39)

        menu_h = _MENU_H
        ctrl_h = _CTRL_H

        # Build primary window theme with zero padding so child windows start at (0,0)
        with dpg.theme() as primary_theme:
            with dpg.theme_component(dpg.mvWindowAppItem):
                dpg.add_theme_style(dpg.mvStyleVar_WindowPadding, 0, 0)
                dpg.add_theme_style(dpg.mvStyleVar_ItemSpacing,   0, 0)

        with dpg.window(tag=self._win_tag, no_title_bar=True, no_resize=True,
                        no_move=True, no_scrollbar=True, no_scroll_with_mouse=True):

            # ── Menu bar ──────────────────────────────────────────────────────
            # No pos= — child windows stack vertically inside the primary window
            self._build_menu_bar()

            # ── Track area (middle — explicit height, leaves room for ctrl bar) ─
            track_h = max(1, vh - menu_h - ctrl_h)
            self._track_area_h = track_h
            self._track_area_w = vw
            self._build_track_area(track_h)

            # ── Control bar (bottom, fixed height) ───────────────────────────
            self._build_ctrl_bar()

        dpg.bind_item_theme(self._win_tag, primary_theme)
        dpg.set_primary_window(self._win_tag, True)

    def _build_menu_bar(self) -> None:
        # width=-1 fills parent; no pos= so it flows naturally
        with dpg.child_window(tag=self._menu_win, width=-1, height=_MENU_H,
                              no_scrollbar=True):
            with dpg.group(horizontal=True):
                dpg.add_button(label="File", callback=self._popup_file_menu,
                               small=True)
                dpg.add_button(label="Settings", callback=self._popup_settings_menu,
                               small=True)
                dpg.add_button(label="Help", callback=self._show_help, small=True)
                dpg.add_button(label="Mode: A/B", tag=self._tag_mode_btn,
                               callback=self._popup_mode_menu, small=True)

    def _build_ctrl_bar(self) -> None:
        h = _CTRL_H
        btn_h = h - 12
        pad_y = (h - btn_h) // 2

        # ctrl_theme: zero ItemSpacing throughout; buttons get FramePadding for height.
        # Dots use a drawlist so theme Text color does not affect them.
        with dpg.theme() as ctrl_theme:
            with dpg.theme_component(dpg.mvButton):
                dpg.add_theme_style(dpg.mvStyleVar_FramePadding, 4, pad_y)
                dpg.add_theme_style(dpg.mvStyleVar_ItemSpacing,  0, 0)
            with dpg.theme_component(dpg.mvAll):
                dpg.add_theme_style(dpg.mvStyleVar_ItemSpacing,  0, 0)

        # slider_theme: per-item, mvSliderInt scope to match button height exactly.
        with dpg.theme() as slider_theme:
            with dpg.theme_component(dpg.mvSliderInt):
                dpg.add_theme_style(dpg.mvStyleVar_FramePadding, 4, pad_y + 1)
                dpg.add_theme_style(dpg.mvStyleVar_ItemSpacing,  0, 0)

        with dpg.child_window(tag=self._ctrl_win, width=-1, height=h,
                              no_scrollbar=True):
            dpg.bind_item_theme(self._ctrl_win, ctrl_theme)
            with dpg.group(horizontal=True):
                dpg.add_spacer(width=6)
                dpg.add_button(label="\u25b6", tag=self._tag_play_btn,
                               callback=self.toggle_play, width=btn_h, height=btn_h)
                if self._font_symbol:
                    dpg.bind_item_font(self._tag_play_btn, self._font_symbol)
                dpg.add_spacer(width=8)
                # Wrap time label in a vertical group with a dummy to center it
                # against btn_h. Font height ~13px; offset = (btn_h - 13) // 2.
                with dpg.group():
                    dpg.add_dummy(height=(btn_h - 13) // 2)
                    dpg.add_text("0:00 / 0:00", tag=self._tag_time_lbl)
                dpg.add_spacer(width=10)

                # Null test controls (hidden in A/B mode)
                dpg.add_button(label="\u00d8", tag=self._tag_null_toggle,
                               callback=self._on_null_toggle, show=False,
                               width=btn_h, height=btn_h)
                dpg.add_text("", tag=self._tag_null_status, show=False)
                dpg.add_button(label="+20 dB", tag=self._tag_null_boost,
                               callback=self._toggle_null_boost, show=False,
                               width=60, height=btn_h)
                dpg.add_text("", tag=self._tag_null_warn, show=False,
                             color=_ORANGE)

                # Two half-spacers with processing label between them.
                # Each is sized to half the full spacer width so the label stays centred.
                dpg.add_spacer(tag="ctrl_spacer_l", width=1)
                with dpg.group():
                    dpg.add_dummy(height=(btn_h - 13) // 2)
                    dpg.add_text("Processing, please wait..",
                                 tag=self._tag_processing_lbl,
                                 show=False,
                                 color=[180, 180, 180, 200])
                dpg.add_spacer(tag="ctrl_spacer_r", width=1)

                # Mute button
                lbl_mute = "\U0001f507" if self._muted else "\U0001f50a"
                dpg.add_button(label=lbl_mute, tag=self._tag_mute_btn,
                               callback=self._toggle_mute,
                               width=btn_h, height=btn_h)
                if self._font_emoji:
                    dpg.bind_item_font(self._tag_mute_btn, self._font_emoji)
                dpg.add_spacer(width=6)
                # Volume slider
                dpg.add_slider_int(
                    tag=self._tag_vol_slider,
                    min_value=0, max_value=100,
                    default_value=self._vol_value,
                    width=140,
                    no_input=True,
                    callback=self._on_vol_slide,
                )
                dpg.bind_item_theme(self._tag_vol_slider, slider_theme)
                dpg.add_spacer(width=16)
                # Track selector dots — drawlist is btn_h tall with circles
                # centered at cy=btn_h//2, so it aligns naturally with buttons.
                dpg.add_group(tag=self._tag_dots_group, horizontal=True)
                dpg.add_spacer(width=8)

    def _build_track_area(self, track_h: int) -> None:
        """Build the track area container with an explicit pixel height."""
        with dpg.child_window(tag=self._tracks_win, width=-1, height=track_h,
                              no_scrollbar=True, border=False,
                              parent=self._win_tag):
            pass
        self._rebuild_track_area()

    def _rebuild_track_area(self) -> None:
        """Destroy and recreate all slot child windows from current track state."""
        # Bump generation — stale deferred callbacks (e.g. _draw_lufs_overlay)
        # check this and discard themselves if they predate the current rebuild.
        self._slot_generation += 1
        # Selectively flush the queue: discard spectrum display callbacks
        # (_apply_spectrum references SpectrumOverlay/SpectrogramStrip draw items
        # that are about to be deleted — keeping them would call configure_item on
        # freed DPG pointers).  Keep wave/decode/lufs done callbacks — they only
        # write to track dicts and numpy arrays (no DPG calls), so they are safe
        # across a rebuild.  Flushing everything caused _on_wave_done to be lost
        # when 4 files were dropped at once, leaving slot 0 with a blank texture.
        if hasattr(self, "_msg_queue"):
            try:
                kept = []
                while not self._msg_queue.empty():
                    item = self._msg_queue.get_nowait()
                    fn = item[0] if isinstance(item, tuple) else None
                    if fn in (self._on_wave_done, self._on_decode_done,
                              self._on_lufs_done):
                        kept.append(item)
                for item in kept:
                    self._msg_queue.put(item)
            except Exception:
                pass
        # Reset spectrum pending flag so the spectrum thread can fire again.
        self._spectrum_pending = False

        vw = self._track_area_w
        h  = self._track_area_h

        # Delete old slot windows
        for i in range(MAX_TRACKS):
            tag = f"slot_win_{i}"
            if dpg.does_item_exist(tag):
                dpg.delete_item(tag)

        # Delete old texture/meter/spectrum objects
        for i in range(MAX_TRACKS):
            if self._slot_textures[i]:
                self._slot_textures[i].delete()
                self._slot_textures[i] = None
            if self._slot_spectra[i]:
                self._slot_spectra[i].delete()
                self._slot_spectra[i] = None
            if self._slot_spectrograms[i]:
                self._slot_spectrograms[i].delete()
                self._slot_spectrograms[i] = None
            self._slot_meters[i]    = None   # meter/corr/dim draw items live in slot_dl, deleted with slot_win
            self._slot_corr[i]      = None
            self._slot_dim_rects[i] = None
        if self._null_tex:
            self._null_tex.delete()
            self._null_tex = None

        slot_h = max(1, (h - _TRACK_PAD * (MAX_TRACKS - 1)) // MAX_TRACKS)

        for i in range(MAX_TRACKS):
            self._build_slot_window(i, vw, slot_h)

        self._update_dim_rects()
        self._refresh_placeholder()

        # Re-apply wave samples for tracks that decoded before this rebuild ran.
        # _rebuild_track_area flushes the message queue, which can discard queued
        # _on_wave_done callbacks if multiple tracks are added in the same tick
        # (e.g. drag-drop 4 files at once).  Re-applying here ensures those tracks
        # don't end up with blank textures.
        wave_w = max(1, vw - METER_W)
        for i, t in enumerate(self._tracks):
            if t.get("wave_raw") and self._slot_textures[i]:
                self._refresh_track_waveform(i)
            # Re-seed spectrogram texture from cached rgba (if already computed).
            # The new SpectrogramStrip has a blank placeholder — set_data() restores it.
            # If the display width changed, also re-launch compute at the new n_cols.
            sg   = self._slot_spectrograms[i]
            rgba = t.get("spectro_rgba")
            if sg and rgba is not None:
                # Always show cached data immediately — no blank gap on resize.
                # If the display width changed, also recompute at the new wave_w.
                sg.set_data(rgba)
                cached_cols = sum(t.shape[1] for t in rgba) if isinstance(rgba, list) else rgba.shape[1]
                if cached_cols != max(wave_w, min(6000, cached_cols)):
                    threading.Thread(
                        target=self._spectro_thread,
                        args=(i, t["path"], wave_w, slot_h),
                        daemon=True,
                    ).start()

        # If fullscreen spectrogram is active, rebuild the floating window at new size
        if self._spectrogram_fullscreen:
            self._destroy_fullscreen_spectrogram()
            self._build_fullscreen_spectrogram()

    def _build_slot_window(self, idx: int, vw: int, h: int) -> None:
        """Build one slot child window — added to tracks_win, stacks naturally (no pos=)."""
        tag = f"slot_win_{idx}"

        # All slot child windows are children of the tracks_win container
        parent = self._tracks_win

        is_null_slot = self._null_mode and idx == 3

        if is_null_slot:
            dpg.add_child_window(tag=tag, width=-1, height=h,
                                 no_scrollbar=True, border=False, parent=parent)
            dpg.bind_item_theme(tag, self._slot_theme)
            self._build_null_slot_content(tag, vw, h)
            return

        if idx >= len(self._tracks):
            dpg.add_child_window(tag=tag, width=-1, height=h,
                                 no_scrollbar=True, border=False, parent=parent)
            dpg.bind_item_theme(tag, self._slot_theme)
            return

        # Track slot
        track  = self._tracks[idx]
        colors = _TRACK_COLORS[track["slot"]]
        bg     = _hex_to_dpg_rgba(colors[0])
        wave_w = max(1, vw - METER_W)

        # Waveform texture — dual static textures, no per-frame upload
        tex = WaveformTexture(
            self._tex_reg, wave_w, h,
            bg_color=colors[0],
            active_color=colors[1],
            inactive_color=colors[2],
            dim_color=colors[3],
            is_active=(idx == self._active),
        )
        self._slot_textures[idx] = tex
        if track.get("wave_raw"):
            tex.set_wave_samples(
                track["wave_raw"], track["duration"], self._max_dur,
                track.get("wave_peak", 1), self._wave_global_peak,
                self._wave_normalize and len(self._tracks) > 1,
            )

        # Child window — no pos=, stacks naturally inside tracks_win; zero padding
        dpg.add_child_window(tag=tag, width=-1, height=h,
                             no_scrollbar=True, border=False, parent=parent)
        dpg.bind_item_theme(tag, self._slot_theme)

        # ── Z-order: items added LATER are drawn ON TOP ────────────────────────
        # 1. Invisible click button added FIRST (bottom of Z-stack) so waveform
        #    drawlist renders on top of it (hiding its blank background).
        #    DPG button hit-testing is bounding-box based and works regardless
        #    of Z-order, so this button still receives all mouse clicks.
        click_tag = f"slot_click_{idx}"
        with dpg.theme() as _invis:
            with dpg.theme_component(dpg.mvButton):
                dpg.add_theme_color(dpg.mvThemeCol_Button,        (0, 0, 0, 0))
                dpg.add_theme_color(dpg.mvThemeCol_ButtonHovered,  (255, 255, 255, 0))
                dpg.add_theme_color(dpg.mvThemeCol_ButtonActive,   (255, 255, 255, 0))
                dpg.add_theme_style(dpg.mvStyleVar_FramePadding,   0, 0)
        dpg.add_button(label="", pos=(0, 0), width=wave_w, height=h,
                       callback=lambda s, a, u: self._on_slot_click(u),
                       user_data=idx, tag=click_tag, parent=tag)
        dpg.bind_item_theme(click_tag, _invis)

        # 2. Waveform + meter drawlist — drawn on top of the click button.
        #    Meter items live directly in this drawlist at x_offset=wave_w.
        dl = dpg.add_drawlist(tag=f"slot_dl_{idx}", width=vw, height=h, parent=tag)
        dpg.draw_rectangle((0, 0), (vw, h), color=(0, 0, 0, 0), fill=bg,
                           tag=f"slot_bg_{idx}", parent=dl)
        # Two static images: rest (full width) drawn first, played on top.
        # pmin/pmax/uv_min/uv_max are updated per-frame in _update_frame.
        dpg.draw_image(tex.tag_rest,   (0, 0), (wave_w, h),
                       uv_min=(0, 0), uv_max=(1, 1),
                       tag=f"slot_wave_rest_{idx}",   parent=dl)
        dpg.draw_image(tex.tag_played, (0, 0), (0,      h),
                       uv_min=(0, 0), uv_max=(0, 1),
                       tag=f"slot_wave_played_{idx}", parent=dl)
        # Dark overlay on top of waveform — always drawn, opacity controls visibility.
        # fill alpha=0 = transparent (inactive), alpha=178 = 70% dark (active+FFT on).
        dim_rect = dpg.draw_rectangle(
            (0, 0), (wave_w, h),
            color=(0, 0, 0, 0), fill=(0, 0, 0, 0),
            tag=f"slot_dim_{idx}",
            parent=dl,
        )
        self._slot_dim_rects[idx] = dim_rect
        # Always create meter and corr bar; show/hide via set_visible so
        # toggling them never requires a full slot rebuild (avoids GIL stalls
        # that cause audio dropouts).
        strip = MeterStrip(
            dl,
            x_offset=wave_w,
            active_color=colors[1],
            inactive_color=colors[2],
            height=h,
        )
        strip.set_visible(self._meter_enabled)
        self._slot_meters[idx] = strip
        corr_bar = CorrelationBar(dl, x_offset=wave_w, slot_height=h)
        corr_bar.set_visible(self._meter_enabled and self._corr_enabled)
        self._slot_corr[idx] = corr_bar

        # 3. Spectrum bars — always created; toggled via set_visible so switching
        #    never requires a slot rebuild (same pattern as MeterStrip).
        spec = SpectrumOverlay(
            texture_registry=self._tex_reg,
            drawlist_tag=dl,
            x_offset=0,
            width=wave_w,
            height=h,
            n_bands=self._fft_bands,
            active_color=colors[1],
        )
        spec.set_visible(self._spectrum_enabled)
        self._slot_spectra[idx] = spec

        # 3b. Spectrogram overlay — mutually exclusive with spectrum bars.
        #     Always created so toggling never requires a rebuild.
        sgram = SpectrogramStrip(
            tex_registry=self._tex_reg,
            drawlist_tag=dl,
            width=wave_w,
            height=h,
            active_color=colors[1],
        )
        sgram.set_visible(self._spectrogram_enabled)
        sgram.set_zoom(self._spectrogram_zoom)
        self._slot_spectrograms[idx] = sgram

        # 4. Track name label (on top of waveform) — bold if font available
        name = os.path.basename(track["path"])
        if self._null_mode and idx < 3:
            name = f"{('[REF]', '[A]', '[B]')[idx]} {name}"
        name_tag = f"slot_name_{idx}"
        dpg.add_text(name, pos=(8, 4),
                     color=list(_BTN_FG if idx == self._active else _DIM_FG),
                     tag=name_tag, parent=tag)
        if self._font_bold:
            dpg.bind_item_font(name_tag, self._font_bold)

        # 5. Playhead line — drawn AFTER spectrogram so it renders on top of everything.
        #    Position updated every frame in _update_frame.
        dpg.draw_line(
            (0, 0), (0, h),
            color=(255, 255, 255, 220), thickness=2,
            tag=f"slot_play_line_{idx}", parent=dl,
        )

        # 6. "x" drawn in the drawlist top-right — brightens when mouse held in
        #    that zone. Removal fires from _on_slot_click hit-zone detection.
        dpg.draw_text((wave_w - 16, 4), "x", size=13,
                      color=(180, 180, 180, 160),
                      tag=f"slot_rm_hint_{idx}", parent=dl)

        # LUFS overlay (if enabled and already computed) — deferred one frame
        # so the slot window has been laid out before we read its rect size.
        if self._lufs_enabled and track.get("lufs_curve") is not None:
            gen = self._slot_generation
            self._post(self._draw_lufs_overlay, idx, gen)

    def _build_null_slot_content(self, parent_tag: str, vw: int, h: int) -> None:
        """Build the waveform + metrics display in the null slot (slot 3)."""
        bg = _hex_to_dpg_rgba(_NULL_SLOT_COLORS[0])

        tex = WaveformTexture(
            self._tex_reg, vw, h,
            bg_color=_NULL_SLOT_COLORS[0],
            active_color=_NULL_SLOT_COLORS[1],
            inactive_color=_NULL_SLOT_COLORS[2],
            dim_color=_NULL_SLOT_COLORS[3],
            is_active=True,
        )
        self._null_tex = tex
        if self._null_wave_raw:
            tex.set_wave_samples(self._null_wave_raw, 1.0, 1.0, 32767, 32767, False)

        # Click button FIRST (bottom Z) so drawlist renders on top
        with dpg.theme() as _invis_null:
            with dpg.theme_component(dpg.mvButton):
                dpg.add_theme_color(dpg.mvThemeCol_Button,        (0, 0, 0, 0))
                dpg.add_theme_color(dpg.mvThemeCol_ButtonHovered,  (255, 255, 255, 0))
                dpg.add_theme_color(dpg.mvThemeCol_ButtonActive,   (255, 255, 255, 0))
                dpg.add_theme_style(dpg.mvStyleVar_FramePadding,   0, 0)
        dpg.add_button(label="", pos=(0, 0), width=vw, height=h,
                       callback=self._on_null_slot_click,
                       tag="null_click_btn", parent=parent_tag)
        dpg.bind_item_theme("null_click_btn", _invis_null)

        # Drawlist on top of button
        dl = dpg.add_drawlist(tag="null_dl", width=vw, height=h, parent=parent_tag)
        dpg.draw_rectangle((0, 0), (vw, h), color=(0,0,0,0), fill=bg,
                           tag="null_bg", parent=dl)
        dpg.draw_image(tex.tag_rest,   (0, 0), (vw, h),
                       uv_min=(0, 0), uv_max=(1, 1),
                       tag="null_wave_rest",   parent=dl)
        dpg.draw_image(tex.tag_played, (0, 0), (0,   h),
                       uv_min=(0, 0), uv_max=(0, 1),
                       tag="null_wave_played", parent=dl)
        dpg.draw_line((0, 0), (0, h), color=(255, 255, 255, 220), thickness=2,
                      tag="null_play_line", parent=dl)

        dpg.add_text("[NULL]", pos=(8, 4), color=list(_DIM_FG),
                     tag="null_label", parent=parent_tag)
        dpg.add_text("", pos=(8, 18),
                     color=list(_hex_to_dpg_rgba(_NULL_SLOT_COLORS[1])),
                     tag="null_metrics_txt", wrap=vw - 16, parent=parent_tag)

    # ── Placeholder text ──────────────────────────────────────────────────────

    def _refresh_placeholder(self) -> None:
        tag = "placeholder_txt"
        if dpg.does_item_exist(tag):
            dpg.delete_item(tag)
        n      = len(self._tracks)
        limit  = MAX_TRACKS_NULL if self._null_mode else MAX_TRACKS
        if n >= limit:
            return
        if self._null_mode:
            if n == 0:
                text = "Load a reference file (REF) to start"
            elif n == 1:
                text = "Load a candidate file (A) to compare against REF"
            else:
                text = "Optionally load a second candidate (B)"
        else:
            text = (
                "Drag and drop audio files here  (or use  File -> Open)\n"
                "You can compare up to 4 files at a time."
                if n == 0
                else "Add additional audio files to compare"
            )
        vw = self._track_area_w
        vh = self._track_area_h
        dpg.add_text(text, tag=tag, color=_DIM_FG,
                     parent=self._tracks_win,
                     pos=(vw // 2 - 160, vh // 2 - 12))

