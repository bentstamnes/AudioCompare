    # ── Mode switching ────────────────────────────────────────────────────────

    def _set_mode(self, null_mode: bool) -> None:
        if null_mode == self._null_mode:
            return
        self._null_mode = null_mode
        self._null_running = False

        if null_mode:
            dpg.configure_item(self._tag_mode_btn, label="Mode: Null")
            self._null_playing_null = False
            self._null_results.clear()
            self._null_arrays.clear()
            self._null_selected = -1
            self._null_wave_raw = None
            self._null_boost    = False
            while len(self._tracks) > MAX_TRACKS_NULL:
                self._engine.remove_buffer(self._tracks[-1]["id"])
                self._tracks.pop()
            if self._active >= len(self._tracks) and self._tracks:
                self._active = 0
            self._engine.remove_buffer(_NULL_TRACK_ID)
            # Show null controls
            for tag in (self._tag_null_toggle, self._tag_null_status,
                        self._tag_null_boost, self._tag_null_warn):
                dpg.configure_item(tag, show=True)
        else:
            dpg.configure_item(self._tag_mode_btn, label="Mode: A/B")
            if self._null_playing_null and self._tracks:
                self._engine.set_active(self._tracks[self._active]["id"])
                self._engine.set_gain(_NULL_TRACK_ID, 1.0)
            self._null_playing_null = False
            self._null_results.clear()
            self._null_arrays.clear()
            self._null_wave_raw = None
            self._engine.remove_buffer(_NULL_TRACK_ID)
            for tag in (self._tag_null_toggle, self._tag_null_status,
                        self._tag_null_boost, self._tag_null_warn):
                dpg.configure_item(tag, show=False)

        self._rebuild_track_area()
        self._update_dots()
        self._update_null_status()

    # ── Track management ──────────────────────────────────────────────────────

    def _add_track(self, path: str) -> None:
        limit = MAX_TRACKS_NULL if self._null_mode else MAX_TRACKS
        if len(self._tracks) >= limit:
            return

        # Duplicate check
        norm = os.path.normcase(os.path.abspath(path))
        for idx, t in enumerate(self._tracks):
            if os.path.normcase(os.path.abspath(t["path"])) == norm:
                self._flash_track(idx)
                return

        if not _HAS_SD:
            self._show_modal_error("sounddevice not available",
                                   "Install sounddevice and numpy:\n  pip install sounddevice numpy")
            return

        slot     = self._next_color_slot()
        idx      = len(self._tracks)
        track_id = self._track_id_counter
        self._track_id_counter += 1

        info = audio_ops.probe_info(path)
        dur  = info["duration"]

        track = {
            "id":           track_id,
            "path":         path,
            "duration":     dur,
            "codec_name":   info.get("codec_name", ""),
            "slot":         slot,
            "audio_ready":  False,
            "audio_peak":   0.0,
            "wave_raw":     None,
            "wave_peak":    1,
            "wave_loading": False,
            "peak_hold":      0.0,
            "peak_hold_time": 0.0,
            "_flash_factor":  0.0,
        }
        self._tracks.append(track)
        old_max = self._max_dur
        self._max_dur = max(t["duration"] for t in self._tracks)

        if idx == 0:
            self._engine.set_active(track_id)

        _log(f"_add_track idx={idx} id={track_id} dur={dur:.1f} path={os.path.basename(path)}")

        # Rebuild the slot for this track
        self._rebuild_slot(idx)
        if self._null_mode:
            self._rebuild_slot(3)  # ensure null slot is built
            if idx > 0:
                self._null_results.pop(idx, None)
                self._null_arrays.pop(idx, None)
                if self._null_playing_null and self._null_selected == idx:
                    self._deactivate_null_playback()
                self._null_wave_raw = None
                self._refresh_null_waveform()
            self._update_null_status()

        self._update_dots()
        self._refresh_placeholder()

        if old_max != self._max_dur:
            for i in range(idx):
                self._refresh_track_waveform(i)

        self._inc_processing("audio")
        self._inc_processing("waveform")
        self._decode_executor.submit(self._decode_thread, track_id, path)
        threading.Thread(target=self._wave_thread,
                         args=(idx, path), daemon=True).start()

    def _rebuild_slot(self, idx: int) -> None:
        """Rebuild all slots (full rebuild preserves correct top-to-bottom order)."""
        _log(f"  _rebuild_slot({idx}) area={self._track_area_w}x{self._track_area_h} ntracks={len(self._tracks)}")
        self._rebuild_track_area()
        _log(f"  _rebuild_slot done textures={[t is not None for t in self._slot_textures]}")

    def _next_color_slot(self) -> int:
        used = {t["slot"] for t in self._tracks}
        for i in range(MAX_TRACKS):
            if i not in used:
                return i
        return 0

    def _decode_thread(self, track_id: int, path: str) -> None:
        try:
            data = audio_ops.decode_audio(path)
            audio_peak = 0.0
            if data is not None:
                audio_peak = float(np.max(np.abs(data)))
            self._post(self._on_decode_done, track_id, data, audio_peak)
        except Exception as e:
            import traceback
            self._post(_log, f"_decode_thread EXCEPTION id={track_id}: {traceback.format_exc()}")
            self._post(self._dec_processing, "audio")

    def _on_decode_done(self, track_id: int, data, audio_peak: float) -> None:
        _log(f"_on_decode_done id={track_id} data={'OK shape='+str(data.shape) if data is not None else 'None'}")
        self._dec_processing("audio")
        for t in self._tracks:
            if t["id"] == track_id:
                if data is not None:
                    self._engine.set_buffer(track_id, data)
                    t["audio_ready"] = True
                    t["audio_peak"]  = audio_peak
                    self._recalc_audio_gains()
                    _log(f"  engine active={self._engine._active} playing={self._engine._playing} buffers={list(self._engine._buffers.keys())}")
                    self._inc_processing("LUFS")
                    self._decode_executor.submit(self._lufs_thread, track_id, data)
                break

    def _lufs_thread(self, track_id: int, data) -> None:
        try:
            # Downsample 48kHz→16kHz before analysis to reduce memory pressure.
            # K-weighting is valid at 16kHz; accuracy is unaffected for LUFS.
            ds = data[::3]
            integrated, curve = audio_ops.analyze_loudness(ds, sr=16000)
            self._post(self._on_lufs_done, track_id, integrated, curve)
        except Exception:
            self._post(self._dec_processing, "LUFS")

    def _on_lufs_done(self, track_id: int, integrated: float, curve) -> None:
        self._dec_processing("LUFS")
        for idx, t in enumerate(self._tracks):
            if t["id"] == track_id:
                t["lufs"]       = integrated
                t["lufs_curve"] = curve
                if self._lufs_enabled:
                    self._draw_lufs_overlay(idx, getattr(self, "_slot_generation", 0))
                break

    def _wave_thread(self, idx: int, path: str) -> None:
        try:
            samples = audio_ops.extract_waveform(path)
            peak    = max((abs(s) for s in samples), default=1) if samples else 1
            self._post(self._on_wave_done, idx, path, samples, peak)
        except Exception:
            import traceback
            self._post(_log, f"_wave_thread EXCEPTION idx={idx}: {traceback.format_exc()}")
            self._post(self._dec_processing, "waveform")

    def _on_wave_done(self, idx: int, path: str, samples: tuple, peak: int) -> None:
        _log(f"_on_wave_done idx={idx} samples={len(samples)} tex={self._slot_textures[idx] is not None}")
        self._dec_processing("waveform")
        if idx >= len(self._tracks) or self._tracks[idx]["path"] != path:
            _log(f"  -> stale, skip")
            return
        t = self._tracks[idx]
        t["wave_raw"]     = samples
        t["wave_peak"]    = peak
        t["wave_loading"] = False
        scale_changed = self._recalc_wave_scale()
        if scale_changed and self._wave_normalize:
            for i in range(len(self._tracks)):
                self._refresh_track_waveform(i)
        else:
            self._refresh_track_waveform(idx)

        # Launch static spectrogram computation in a background thread.
        # Samples are already available and the display geometry is stable.
        wave_w = max(1, self._track_area_w - METER_W)
        slot_h = max(1, (self._track_area_h - _TRACK_PAD * (MAX_TRACKS - 1)) // MAX_TRACKS)
        self._inc_processing("FFT")
        threading.Thread(
            target=self._spectro_thread,
            args=(idx, path, wave_w, slot_h),
            daemon=True,
        ).start()

    def _spectro_thread(self, idx: int, path: str,
                        wave_w: int, slot_h: int) -> None:
        try:
            from renderers.spectrogram import (
                compute_static, n_cols_for_samples, decode_sample_rate,
            )
            info        = audio_ops.probe_info(path)
            sr          = decode_sample_rate(info["sample_rate"])
            audio       = audio_ops.decode_audio(path, samplerate=sr, channels=1)
            if audio is None:
                self._post(self._dec_processing, "FFT")
                return
            n_samp = audio.shape[0]
            n_cols = n_cols_for_samples(n_samp, wave_w)
            rgba   = compute_static(audio, n_cols, slot_h, sr)
            self._post(self._on_spectro_done, idx, path, rgba)
        except Exception:
            import traceback
            self._post(_log, f"_spectro_thread EXCEPTION idx={idx}: {traceback.format_exc()}")
            self._post(self._dec_processing, "FFT")

    def _on_spectro_done(self, idx: int, path: str, rgba) -> None:
        self._dec_processing("FFT")
        if idx >= len(self._tracks) or self._tracks[idx]["path"] != path:
            return   # stale
        self._tracks[idx]["spectro_rgba"] = rgba   # cache for slot display
        sg = self._slot_spectrograms[idx] if idx < len(self._slot_spectrograms) else None
        if sg:
            sg.set_data(rgba)

    def _spectro_fs_thread(self, idx: int, path: str,
                           wave_w: int, vh: int) -> None:
        """Compute fullscreen spectrogram at the viewport's full height."""
        try:
            from renderers.spectrogram import (
                compute_static, n_cols_for_samples, decode_sample_rate,
            )
            info        = audio_ops.probe_info(path)
            sr          = decode_sample_rate(info["sample_rate"])
            audio       = audio_ops.decode_audio(path, samplerate=sr, channels=1)
            if audio is None:
                self._post(self._dec_processing, "FFT")
                return
            n_samp = audio.shape[0]
            n_cols = n_cols_for_samples(n_samp, wave_w)
            rgba   = compute_static(audio, n_cols, vh, sr)
            self._post(self._on_spectro_fs_done, idx, path, rgba)
        except Exception:
            import traceback
            self._post(_log, f"_spectro_fs_thread EXCEPTION idx={idx}: {traceback.format_exc()}")
            self._post(self._dec_processing, "FFT")

    def _on_spectro_fs_done(self, idx: int, path: str, rgba) -> None:
        self._dec_processing("FFT")
        if idx >= len(self._tracks) or self._tracks[idx]["path"] != path:
            return   # stale
        self._tracks[idx]["spectro_fs_rgba"] = rgba   # cache for fullscreen
        if self._spectrogram_fullscreen and self._fs_strip and idx == self._active:
            self._fs_strip.set_data(rgba)

    def _draw_lufs_overlay(self, idx: int, generation: int = -1) -> None:
        """Draw (or redraw) LUFS curve polyline and score label for slot idx."""
        if generation >= 0 and generation != getattr(self, "_slot_generation", 0):
            return  # stale deferred call from a previous rebuild
        if idx >= len(self._tracks):
            return
        t     = self._tracks[idx]
        curve = t.get("lufs_curve")
        lufs  = t.get("lufs", float("-inf"))
        dl_tag = f"slot_dl_{idx}"
        if not dpg.does_item_exist(dl_tag) or curve is None:
            return

        meter_w  = METER_W
        slot_tag = f"slot_win_{idx}"
        slot_w   = slot_h = 0
        if dpg.does_item_exist(slot_tag):
            sz     = dpg.get_item_rect_size(slot_tag)
            slot_w = int(sz[0])
            slot_h = int(sz[1])
        if slot_w < 2 or slot_h < 2:
            # Not yet laid out — retry one frame later via frame callback (NOT
            # via _post, which can flood the queue if layout takes several frames).
            dpg.set_frame_callback(
                dpg.get_frame_count() + 1,
                lambda: self._draw_lufs_overlay(idx, generation),
            )
            return
        wave_w = max(1, slot_w - meter_w)

        # Remove old overlay items if they exist
        for tag in (f"lufs_line_{idx}", f"lufs_score_{idx}"):
            if dpg.does_item_exist(tag):
                dpg.delete_item(tag)

        # Map curve values to pixel Y: -9 LUFS = top, -36 LUFS = bottom
        _LUFS_TOP    = -9.0
        _LUFS_BOTTOM = -36.0
        _LUFS_RANGE  = _LUFS_BOTTOM - _LUFS_TOP   # negative

        n        = len(curve)
        points   = []
        # Scale the curve to the track's own duration, not the full wave_w.
        # Shorter tracks must not be stretched to fill the slot width.
        track_dur = t.get("duration", self._max_dur) or self._max_dur
        dur_frac  = min(1.0, track_dur / self._max_dur) if self._max_dur > 0 else 1.0
        x_scale   = (wave_w * dur_frac) / max(n - 1, 1)
        for i, v in enumerate(curve):
            v_clamped = max(_LUFS_BOTTOM, min(_LUFS_TOP, float(v)))
            y = (v_clamped - _LUFS_TOP) / _LUFS_RANGE * slot_h
            points.append((i * x_scale, y))

        dpg.draw_polyline(
            points,
            color=(255, 255, 255, 160),
            thickness=1,
            tag=f"lufs_line_{idx}",
            parent=dl_tag,
        )

        score_txt = f"{lufs:.1f} LUFS" if lufs > -200 else "-- LUFS"
        dpg.draw_text(
            (8, slot_h - 16),
            score_txt,
            color=(255, 255, 255, 200),
            size=11,
            tag=f"lufs_score_{idx}",
            parent=dl_tag,
        )

    def _refresh_track_waveform(self, idx: int) -> None:
        """Push updated waveform samples to the texture for slot idx."""
        if idx >= len(self._tracks):
            return
        tex = self._slot_textures[idx]
        if not tex:
            return
        t = self._tracks[idx]
        if not t.get("wave_raw"):
            return
        tex.set_wave_samples(
            t["wave_raw"], t["duration"], self._max_dur,
            t.get("wave_peak", 1), self._wave_global_peak,
            self._wave_normalize and len(self._tracks) > 1,
        )

    def _refresh_null_waveform(self) -> None:
        if not self._null_tex or not self._null_wave_raw:
            return
        self._null_tex.set_wave_samples(
            self._null_wave_raw, 1.0, 1.0, 32767, 32767, False,
        )

    def _remove_track(self, idx: int) -> None:
        if idx >= len(self._tracks):
            return
        self._engine.remove_buffer(self._tracks[idx]["id"])
        self._tracks.pop(idx)
        if self._active >= len(self._tracks):
            self._active = max(0, len(self._tracks) - 1)
        if self._tracks:
            self._engine.set_active(self._tracks[self._active]["id"])
        if self._null_mode:
            self._null_results.clear()
            self._null_arrays.clear()
            self._null_wave_raw = None
            if self._null_playing_null:
                self._null_playing_null = False
                self._engine.remove_buffer(_NULL_TRACK_ID)
        self._rebuild_track_area()
        self._update_null_status()

    # ── Thread-safe message queue ─────────────────────────────────────────────

    def __init_queue(self) -> None:
        import queue
        self._msg_queue: "queue.Queue" = queue.Queue()

    def _post(self, fn, *args) -> None:
        """Queue a callable for execution on the main (DPG) thread."""
        self._msg_queue.put((fn, args))

    def _drain_queue(self) -> None:
        if not hasattr(self, "_msg_queue"):
            return
        while not self._msg_queue.empty():
            try:
                fn, args = self._msg_queue.get_nowait()
                fn(*args)
            except Exception as _e:
                _log(f"_drain_queue err in {getattr(fn,'__name__','?')}: {_e}")

    def _drain_dnd_queue(self) -> None:
        """Drain file paths posted by the COM Drop handler and load them."""
        q = getattr(self, "_dnd_queue", None)
        if q is None:
            return
        while not q.empty():
            try:
                paths = q.get_nowait()
                self._on_os_drop(paths)
            except Exception:
                import traceback
                _log(f"_drain_dnd_queue exception:\n{traceback.format_exc()}")

    # ── Per-frame update ──────────────────────────────────────────────────────

    def _on_first_frame(self) -> None:
        """Called once after DPG renders the first frame."""
        try:
            import queue
            self._msg_queue = queue.Queue()
            self._dnd_queue = queue.Queue()

            # Register OS drag-and-drop
            self._hwnd = win_drop.find_viewport_hwnd("MixABTest GPU")
            if self._hwnd:
                win_drop.register_drop_target(self._hwnd, self._on_os_drop,
                                              self._dnd_queue)

            # Force a layout update now that the viewport is fully visible and sized
            self._on_viewport_resize()
            self._update_ctrl_spacer()

            # Load any files passed on the command line
            if self._initial_files:
                files = self._initial_files[:MAX_TRACKS]
                def _load():
                    for f in files:
                        self._add_track(f)
                threading.Thread(target=lambda: (time.sleep(0.3), self._post(_load)),
                                 daemon=True).start()
        except Exception:
            pass
        finally:
            self._tick_ready = True

    def _tick(self) -> None:
        """Called every frame from the render loop."""
        self._perf.begin_tick()
        try:
            self._perf.begin_section("drain_queue")
            self._drain_queue()
            self._drain_dnd_queue()
            self._perf.end_section("drain_queue")

            self._perf.begin_section("ctrl_spacer")
            self._update_ctrl_spacer()
            self._perf.end_section("ctrl_spacer")

            self._perf.begin_section("dot_click")
            self._check_dot_click()
            self._perf.end_section("dot_click")

            self._perf.begin_section("frame")
            self._update_frame()
            self._perf.end_section("frame")
        except Exception as _e:
            _log(f"_tick err: {_e}")
        finally:
            self._perf.end_tick()

    def _update_frame(self) -> None:
        """Per-frame update: position, playhead, waveform colours, meters, spectrum."""
        if not self._tracks:
            return

        pos     = self._engine.position
        max_dur = self._max_dur
        if max_dur <= 0:
            return

        self._position = pos
        frac = min(1.0, pos / max_dur)

        # Time label
        dpg.configure_item(self._tag_time_lbl,
                           default_value=f"{_fmt_time(pos)} / {_fmt_time(max_dur)}")

        # Waveform: update UV split on pre-built static textures — no GPU upload
        self._perf.begin_section("waveform")
        for idx, t in enumerate(self._tracks):
            tex = self._slot_textures[idx]
            if not tex:
                continue
            slot_tag = f"slot_win_{idx}"
            if dpg.does_item_exist(slot_tag):
                sz     = dpg.get_item_rect_size(slot_tag)
                slot_w = max(1, int(sz[0]))
                slot_h = max(1, int(sz[1]))
            else:
                slot_w = self._track_area_w
                slot_h = max(1, (self._track_area_h - _TRACK_PAD * (MAX_TRACKS - 1)) // MAX_TRACKS)
            wave_w  = slot_w - METER_W
            play_px = int(wave_w * frac) if max_dur > 0 else -1

            played_tag = f"slot_wave_played_{idx}"
            rest_tag   = f"slot_wave_rest_{idx}"
            is_active  = (idx == self._active)

            if is_active and play_px >= 0:
                split      = min(play_px, wave_w)
                split_frac = split / wave_w if wave_w > 0 else 0.0
                if dpg.does_item_exist(played_tag):
                    dpg.configure_item(played_tag,
                                       pmin=(0, 0), pmax=(split, slot_h),
                                       uv_min=(0, 0), uv_max=(split_frac, 1))
                if dpg.does_item_exist(rest_tag):
                    dpg.configure_item(rest_tag,
                                       pmin=(split, 0), pmax=(wave_w, slot_h),
                                       uv_min=(split_frac, 0), uv_max=(1, 1))
            else:
                # Inactive track or no playhead: show full rest texture
                if dpg.does_item_exist(played_tag):
                    dpg.configure_item(played_tag,
                                       pmin=(0, 0), pmax=(0, slot_h),
                                       uv_min=(0, 0), uv_max=(0, 1))
                if dpg.does_item_exist(rest_tag):
                    dpg.configure_item(rest_tag,
                                       pmin=(0, 0), pmax=(wave_w, slot_h),
                                       uv_min=(0, 0), uv_max=(1, 1))

            # Spectrogram UV scroll — playhead pinned at right edge
            sg = self._slot_spectrograms[idx] if idx < len(self._slot_spectrograms) else None
            if sg and self._spectrogram_enabled:
                sg.set_scroll(frac)

            line_tag = f"slot_play_line_{idx}"
            if play_px >= 0 and dpg.does_item_exist(line_tag):
                # Spectrogram scroll: "now" is always at the right edge of the display
                line_x = wave_w if (self._spectrogram_enabled and sg) else play_px
                dpg.configure_item(line_tag, p1=(line_x, 0), p2=(line_x, slot_h))

        # Null slot waveform: UV split + playhead line
        if self._null_mode and self._null_tex and self._null_wave_raw:
            slot_tag = "slot_win_3"
            if dpg.does_item_exist(slot_tag):
                sz     = dpg.get_item_rect_size(slot_tag)
                null_w = max(1, int(sz[0]))
                null_h = max(1, int(sz[1]))
            else:
                null_w = self._track_area_w
                null_h = max(1, (self._track_area_h - _TRACK_PAD * (MAX_TRACKS - 1)) // MAX_TRACKS)
            play_px    = int(null_w * frac)
            split_frac = play_px / null_w if null_w > 0 else 0.0
            if dpg.does_item_exist("null_wave_played"):
                dpg.configure_item("null_wave_played",
                                   pmin=(0, 0), pmax=(play_px, null_h),
                                   uv_min=(0, 0), uv_max=(split_frac, 1))
            if dpg.does_item_exist("null_wave_rest"):
                dpg.configure_item("null_wave_rest",
                                   pmin=(play_px, 0), pmax=(null_w, null_h),
                                   uv_min=(split_frac, 0), uv_max=(1, 1))
            if dpg.does_item_exist("null_play_line"):
                dpg.configure_item("null_play_line",
                                   p1=(play_px, 0), p2=(play_px, null_h))
        self._perf.end_section("waveform")

        # Meters
        self._perf.begin_section("meters")
        if self._meter_enabled:
            levels = self._engine.sample_levels()
            for idx, t in enumerate(self._tracks):
                strip = self._slot_meters[idx]
                if not strip:
                    continue
                slot_tag = f"slot_win_{idx}"
                if dpg.does_item_exist(slot_tag):
                    sz = dpg.get_item_rect_size(slot_tag)
                    slot_h = max(1, int(sz[1]))
                else:
                    slot_h = max(1, (self._track_area_h - _TRACK_PAD * (MAX_TRACKS - 1)) // MAX_TRACKS)
                meter_h = slot_h - (CORR_TOTAL if self._corr_enabled else 0)
                rms, peak = levels.get(t["id"], (0.0, 0.0))
                strip.update(rms, peak, self._playing, meter_h)

        # Stereo correlation bars
        if self._corr_enabled and self._meter_enabled:
            corrs = self._engine.sample_correlation()
            for idx, t in enumerate(self._tracks):
                bar = self._slot_corr[idx]
                if not bar:
                    continue
                corr = corrs.get(t["id"], 0.0)
                bar.update(corr, self._playing)
        self._perf.end_section("meters")

        # Fullscreen spectrogram: UV scroll + playhead at right edge
        if self._spectrogram_fullscreen:
            wave_w = max(1, self._track_area_w - METER_W)
            if self._fs_strip:
                self._fs_strip.set_scroll(frac)
            if dpg.does_item_exist("fs_play_line"):
                dpg.configure_item("fs_play_line",
                                   p1=(wave_w, 0),
                                   p2=(wave_w, self._track_area_h))

        # Spectrum / spectrogram (every other frame to save CPU)
        self._perf.begin_section("spectrum_dispatch")
        need_fft = self._spectrum_enabled or self._spectrogram_enabled or self._spectrogram_fullscreen
        if need_fft and not self._spectrum_pending:
            self._spectrum_frame_skip += 1
            if self._spectrum_frame_skip >= 2:
                self._spectrum_frame_skip = 0
                self._update_spectrum()
        self._perf.end_section("spectrum_dispatch")

        # Playback end check
        if self._playing and pos >= max_dur - 0.05:
            self._on_playback_end_threadsafe()

    def _inc_processing(self, name: str = "") -> None:
        """Call from main thread when a background task starts."""
        self._processing_tasks[name] = self._processing_tasks.get(name, 0) + 1
        self._refresh_processing_lbl()

    def _dec_processing(self, name: str = "") -> None:
        """Call from main thread when a background task completes (success or error)."""
        if name in self._processing_tasks:
            self._processing_tasks[name] -= 1
            if self._processing_tasks[name] <= 0:
                del self._processing_tasks[name]
        self._refresh_processing_lbl()

    def _refresh_processing_lbl(self) -> None:
        if not dpg.does_item_exist(self._tag_processing_lbl):
            return
        active = [n for n in self._processing_tasks if self._processing_tasks[n] > 0 and n]
        if active:
            names = ", ".join(active)
            dpg.configure_item(self._tag_processing_lbl,
                               default_value=f"Processing ({names}), please wait..",
                               show=True)
        else:
            dpg.configure_item(self._tag_processing_lbl, show=False)

    def _update_ctrl_spacer(self) -> None:
        """Size the two half-spacers so right-side items hug the right edge
        and the processing label (if visible) stays horizontally centred.
        """
        if not dpg.does_item_exist("ctrl_spacer_l"):
            return
        vw = self._track_area_w
        if vw <= 1:
            return
        try:
            mute_pos = dpg.get_item_rect_min(self._tag_mute_btn)
            mute_x   = int(mute_pos[0]) if mute_pos else -1
            if mute_x < 0:
                return
            n_dots        = len(self._tracks)
            dot_total     = n_dots * 8 + max(n_dots - 1, 0) * 8 if n_dots > 0 else 0
            btn_h         = _CTRL_H - 12
            fixed_right_w = btn_h + 6 + 140 + 16 + dot_total + 8
            delta         = (vw - fixed_right_w) - mute_x

            cur_l = dpg.get_item_configuration("ctrl_spacer_l").get("width", 1)
            cur_r = dpg.get_item_configuration("ctrl_spacer_r").get("width", 1)
            total = max(8, cur_l + cur_r + delta)

            # When the label is visible, measure its rendered width and keep it centred.
            # When hidden its width is 0 so we split the space evenly.
            lbl_w = 0
            if (self._processing_tasks
                    and dpg.does_item_exist(self._tag_processing_lbl)):
                try:
                    sz    = dpg.get_item_rect_size(self._tag_processing_lbl)
                    lbl_w = int(sz[0]) if sz else 0
                except Exception:
                    pass
            half       = max(1, (total - lbl_w) // 2)
            spacer_r   = max(1, total - lbl_w - half)
            dpg.configure_item("ctrl_spacer_l", width=half)
            dpg.configure_item("ctrl_spacer_r", width=spacer_r)
        except Exception:
            pass

    # ── Spectrum update ───────────────────────────────────────────────────────

    def _update_spectrum(self) -> None:
        self._spectrum_pending = True
        active_id  = self._tracks[self._active]["id"] if self._tracks else None
        track_ids  = [active_id] if (self._fft_show_active and active_id) else None
        threading.Thread(
            target=self._spectrum_thread,
            args=(track_ids, active_id),
            daemon=True,
        ).start()

    def _spectrum_thread(self, track_ids, active_id) -> None:
        try:
            spectra = self._engine.sample_spectrum(track_ids)
            self._post(self._apply_spectrum, spectra, active_id)
        except Exception:
            import traceback
            self._post(_log, f"_spectrum_thread EXCEPTION: {traceback.format_exc()}")
            self._spectrum_pending = False

    def _apply_spectrum(self, spectra: dict, active_id) -> None:
        """Update real-time spectrum bar overlays only.

        Spectrogram textures are pre-computed at load time and never updated
        per-frame — they are static textures, same pattern as the waveform.
        """
        try:
            n_bands = self._fft_bands
            for idx, t in enumerate(self._tracks):
                tid = t["id"]
                is_active = tid == active_id
                hide = self._fft_show_active and not is_active

                ov = self._slot_spectra[idx]
                if ov:
                    ov.set_visible(not hide and self._spectrum_enabled)
                    if not hide:
                        ov.set_active(is_active)
                        ov.update(spectra.get(tid), self._playing, n_bands)

                sg = self._slot_spectrograms[idx]
                if sg:
                    sg.set_visible(not hide and self._spectrogram_enabled)
        finally:
            self._spectrum_pending = False

    # ── Null test ─────────────────────────────────────────────────────────────

    def _null_candidate_idx(self) -> int:
        if not self._null_mode or len(self._tracks) < 2:
            return -1
        idx = self._active
        if idx == 0:
            idx = 1 if len(self._tracks) > 1 else -1
        return idx

    def _on_null_toggle(self) -> None:
        if not self._null_mode:
            return
        if self._null_playing_null:
            self._deactivate_null_playback()
            return
        cand_idx = self._null_candidate_idx()
        if cand_idx < 0:
            return
        self._null_selected = cand_idx
        if cand_idx in self._null_arrays:
            self._activate_null_playback(cand_idx)
        else:
            self._run_null_computation(cand_idx)

    def _activate_null_playback(self, cand_idx: int) -> None:
        null_arr = self._null_arrays.get(cand_idx)
        if null_arr is None:
            return
        gain = 10.0 if self._null_boost else 1.0
        self._engine.set_buffer(_NULL_TRACK_ID, null_arr)
        self._engine.set_gain(_NULL_TRACK_ID, gain)
        self._engine.set_active(_NULL_TRACK_ID)
        self._null_playing_null = True
        self._update_null_status()
        self._update_null_metrics_text()

    def _deactivate_null_playback(self) -> None:
        self._null_playing_null = False
        if self._tracks and self._active < len(self._tracks):
            self._engine.set_active(self._tracks[self._active]["id"])
        self._update_null_status()

    def _toggle_null_boost(self) -> None:
        self._null_boost = not self._null_boost
        if self._null_playing_null:
            self._engine.set_gain(_NULL_TRACK_ID, 10.0 if self._null_boost else 1.0)
        self._update_null_status()

    def _run_null_computation(self, cand_idx: int) -> None:
        if self._null_running or cand_idx >= len(self._tracks):
            return
        self._null_running = True
        dpg.configure_item(self._tag_null_toggle, enabled=False)
        dpg.configure_item(self._tag_null_status,
                           default_value="Computing...", color=list(_DIM_FG))
        path_ref  = self._tracks[0]["path"]
        path_cand = self._tracks[cand_idx]["path"]
        self._inc_processing("null test")
        threading.Thread(
            target=self._null_thread,
            args=(cand_idx, path_ref, path_cand),
            daemon=True,
        ).start()

    def _null_thread(self, cand_idx: int, path_ref: str, path_cand: str) -> None:
        try:
            metrics, null_f32 = null_ops.run_null_test(path_ref, path_cand)
            self._post(self._null_done, cand_idx, metrics, null_f32)
        except Exception as exc:
            self._post(self._null_done_error, str(exc))

    def _null_done(self, cand_idx: int, metrics: dict, null_f32) -> None:
        self._dec_processing("null test")
        self._null_running = False
        dpg.configure_item(self._tag_null_toggle, enabled=True)
        self._null_results[cand_idx] = metrics
        self._null_arrays[cand_idx]  = null_f32
        self._null_selected          = cand_idx
        sr = metrics.get("sample_rate", 48000)
        self._null_wave_raw = null_ops.downsample_for_waveform(null_f32, sr)
        self._null_wave_sr  = sr
        self._refresh_null_waveform()
        self._update_null_status()
        self._update_null_metrics_text()
        self._activate_null_playback(cand_idx)

    def _null_done_error(self, message: str) -> None:
        self._dec_processing("null test")
        self._null_running = False
        dpg.configure_item(self._tag_null_toggle, enabled=True)
        dpg.configure_item(self._tag_null_status,
                           default_value="Error", color=list(_ERR_FG))
        self._show_modal_error("Null test failed", message)
        self._update_null_status()

    def _update_null_status(self) -> None:
        if not self._null_mode:
            return
        if self._null_running:
            return

        cand_idx = self._null_selected
        if cand_idx >= 0 and cand_idx in self._null_results:
            m = self._null_results[cand_idx]
            lbl = "A" if cand_idx == 1 else "B"
            txt = f"[{lbl}] {m['null_floor_db']:+.1f} dBr  {m['interpretation']}"
            dpg.configure_item(self._tag_null_status,
                               default_value=txt, color=list(_BTN_FG))
        elif not self._tracks or len(self._tracks) < 2:
            dpg.configure_item(self._tag_null_status,
                               default_value="Load REF + candidate", color=list(_DIM_FG))
        else:
            dpg.configure_item(self._tag_null_status,
                               default_value="Press O to run null test", color=list(_DIM_FG))

        # Null toggle button label — indicate active playback state
        lbl = "\u00d8 [ON]" if self._null_playing_null else "\u00d8"
        dpg.configure_item(self._tag_null_toggle, label=lbl)

        boost_lbl = "+20 dB [ON]" if self._null_boost else "+20 dB"
        dpg.configure_item(self._tag_null_boost, label=boost_lbl)

        self._update_lossy_warning()

    def _update_null_metrics_text(self) -> None:
        if not dpg.does_item_exist("null_metrics_txt"):
            return
        cand_idx = self._null_selected
        if cand_idx < 0 or cand_idx not in self._null_results:
            dpg.configure_item("null_metrics_txt", default_value="")
            return
        m   = self._null_results[cand_idx]
        lbl = "A" if cand_idx == 1 else "B"
        txt = (
            f"[{lbl}]  floor {m['null_floor_db']:+.1f} dBr"
            f"   peak {m['null_peak_db']:+.1f} dBFS"
            f"   crest {m['null_crest_db']:.1f} dB"
            f"   lag {m['lag_ms']:+.2f} ms"
            f"   gain {m['gain_applied_db']:+.2f} dB   "
            f"corr {m['signal_correlation']:.6f}   {m['interpretation']}"
        )
        dpg.configure_item("null_metrics_txt", default_value=txt)

    def _update_lossy_warning(self) -> None:
        if not self._null_mode:
            return
        lossy = [t for t in self._tracks
                 if t.get("codec_name", "").lower() in _LOSSY_CODECS]
        if lossy:
            names = ", ".join(sorted({t["codec_name"].upper() for t in lossy}))
            dpg.configure_item(self._tag_null_warn,
                               default_value=f"! Lossy ({names}) - null will be noisy")
        else:
            dpg.configure_item(self._tag_null_warn, default_value="")

    # ── Playback controls ─────────────────────────────────────────────────────

    def toggle_play(self) -> None:
        if not self._tracks:
            _log("toggle_play: no tracks")
            return
        self._playing = not self._playing
        _log(f"toggle_play: playing={self._playing} engine_active={self._engine._active} buffers={list(self._engine._buffers.keys())}")
        dpg.configure_item(self._tag_play_btn,
                           label="\u23f8" if self._playing else "\u25b6")
        if self._playing:
            self._engine.play()
        else:
            self._engine.pause()

    def _seek_to(self, secs: float) -> None:
        if not self._tracks or self._max_dur <= 0:
            return
        secs = max(0.0, min(self._max_dur, secs))
        self._position = secs
        self._engine.seek(secs)

    def _seek_relative(self, delta: float) -> None:
        self._seek_to(self._position + delta)

    def _set_active(self, idx: int) -> None:
        if idx < 0 or idx >= len(self._tracks):
            return
        t = self._tracks[idx]
        if t["duration"] > 0 and self._position > t["duration"]:
            return
        old          = self._active
        self._active = idx

        # Rebuild rest textures for the two affected slots (once per switch)
        if old != idx:
            old_tex = self._slot_textures[old] if 0 <= old < len(self._slot_textures) else None
            new_tex = self._slot_textures[idx]
            if old_tex:
                old_tex.set_active(False)
            if new_tex:
                new_tex.set_active(True)

        if self._null_mode and self._null_playing_null:
            new_cand = self._null_candidate_idx()
            if new_cand >= 0:
                self._null_selected = new_cand
                if new_cand in self._null_arrays:
                    self._activate_null_playback(new_cand)
                else:
                    self._null_playing_null = False
                    self._engine.set_active(t["id"])
                    self._run_null_computation(new_cand)
            else:
                self._engine.set_active(t["id"])
        else:
            self._engine.set_active(t["id"])

        # Update name label colours and dim overlay
        self._update_name_colors()
        self._update_dots()
        self._update_dim_rects()
        if self._spectrogram_fullscreen:
            self._update_fullscreen_track_name()
            # Recompute the fullscreen spectrogram at viewport height for the new track.
            # spectro_rgba is slot-height — passing it to _fs_strip would crash (size mismatch).
            if self._fs_strip and idx < len(self._tracks):
                t = self._tracks[idx]
                if t.get("wave_raw"):
                    wave_w = max(1, self._track_area_w - METER_W)
                    vh     = self._track_area_h
                    self._inc_processing("FFT")
                    threading.Thread(
                        target=self._spectro_fs_thread,
                        args=(idx, t["path"], wave_w, vh),
                        daemon=True,
                    ).start()
        if self._null_mode:
            self._update_null_status()

    def _update_name_colors(self) -> None:
        for i in range(len(self._tracks)):
            tag = f"slot_name_{i}"
            if dpg.does_item_exist(tag):
                col = _BTN_FG if i == self._active else _DIM_FG
                dpg.configure_item(tag, color=list(col))

    def _switch_track(self, direction: int) -> None:
        n = len(self._tracks)
        if n == 0:
            return
        new_idx = (self._active + direction) % n
        for _ in range(n):
            t = self._tracks[new_idx]
            if t["duration"] <= 0 or self._position <= t["duration"]:
                self._set_active(new_idx)
                return
            new_idx = (new_idx + direction) % n

    def _on_playback_end_threadsafe(self) -> None:
        """Can be called from audio thread — deferred via queue."""
        self._post(self._on_playback_end)

    def _on_playback_end(self) -> None:
        if not self._playing:
            return
        self._playing = False
        dpg.configure_item(self._tag_play_btn, label="\u25b6")

    # ── Slot click ────────────────────────────────────────────────────────────

    def _on_slot_click(self, idx: int) -> None:
        if idx >= len(self._tracks):
            return
        mx, my = dpg.get_mouse_pos(local=True)
        wave_w = self._track_area_w - METER_W
        # Top-right corner of waveform area = remove button hit zone.
        # Guard: mx and my must be within plausible slot bounds to avoid
        # spurious removes from stale local-coord values.
        slot_h = max(1, self._track_area_h // max(1, len(self._tracks)))
        if 0 <= my < 20 and 0 <= mx and mx > wave_w - 24 and wave_w > 24:
            self._remove_track(idx)
            return
        self._set_active(idx)
        frac = max(0.0, min(1.0, mx / max(1, wave_w)))
        self._seek_to(frac * self._max_dur)

    def _on_null_slot_click(self) -> None:
        mx, _ = dpg.get_mouse_pos(local=True)
        if self._max_dur > 0:
            frac = max(0.0, min(1.0, mx / max(1, self._track_area_w)))
            self._seek_to(frac * self._max_dur)

    # ── Dots ──────────────────────────────────────────────────────────────────

    def _update_dots(self) -> None:
        tag = self._tag_dots_group
        if not dpg.does_item_exist(tag):
            return
        # Clear existing children
        for child in dpg.get_item_children(tag, 1):
            dpg.delete_item(child)
        self._update_ctrl_spacer()
        n = len(self._tracks)
        if n == 0:
            return
        dot_sz  = 8    # ~40% of original 14px
        gap     = 8
        total_w = n * dot_sz + max(n - 1, 0) * gap
        btn_h   = _CTRL_H - 12   # 32 — same as buttons
        cy      = btn_h // 2     # center within btn_h row, aligns with button centers

        # Drawlist height = btn_h so it aligns with buttons in the horizontal group.
        # Circles drawn at cy = btn_h//2 to match button vertical centers exactly.
        dl = dpg.add_drawlist(width=total_w, height=btn_h, parent=tag)
        for i, t in enumerate(self._tracks):
            colors    = _TRACK_COLORS[t["slot"]]
            is_active = (i == self._active)
            r, g, b, _ = _hex_to_dpg_rgba(colors[1])
            alpha = 255 if is_active else 160
            cx = i * (dot_sz + gap) + dot_sz // 2
            dpg.draw_circle((cx, cy), dot_sz // 2,
                            color=(0, 0, 0, 0), fill=(r, g, b, alpha),
                            segments=32,
                            tag=f"dot_circle_{i}", parent=dl)

        # Store drawlist tag so _tick can handle dot clicks via mouse polling
        self._dot_drawlist = dl
        self._dot_sz  = dot_sz
        self._dot_gap = gap
        self._dot_n   = n

    def _check_dot_click(self) -> None:
        """Poll mouse to handle clicks on the dot drawlist."""
        if not self._dot_drawlist or self._dot_n == 0:
            return
        if not dpg.does_item_exist(self._dot_drawlist):
            return
        pressed = dpg.is_mouse_button_clicked(0)
        if not pressed:
            self._dot_clicked = False
            return
        if self._dot_clicked:
            return  # already handled this click
        try:
            state = dpg.get_item_state(self._dot_drawlist)
            if "rect_min" not in state:
                return
            mx, my = dpg.get_mouse_pos(local=False)
            x0, y0 = state["rect_min"]
            x1, y1 = state["rect_max"]
            if not (x0 <= mx <= x1 and y0 <= my <= y1):
                return
            lx = mx - x0
            idx = int(lx // (self._dot_sz + self._dot_gap))
            idx = max(0, min(self._dot_n - 1, idx))
            self._dot_clicked = True
            self._set_active(idx)
        except Exception:
            pass

    # ── Flash animation ───────────────────────────────────────────────────────

    def _flash_track(self, idx: int) -> None:
        """Brief brightness pulse on a slot to indicate duplicate-drop."""
        if idx >= len(self._tracks):
            return
        # Implemented as a rapid overlay rectangle flash in _update_frame would be complex.
        # For now, just highlight the slot name label briefly.
        tag = f"slot_name_{idx}"
        if dpg.does_item_exist(tag):
            dpg.configure_item(tag, color=list(_WHITE))
            # Reset after ~300 ms (checked in next tick)
            self._flash_reset_frame = dpg.get_frame_count() + 18  # ~300ms @60fps
            self._flash_reset_idx   = idx

    # ── Volume ────────────────────────────────────────────────────────────────

    def _on_vol_slide(self, sender, app_data) -> None:
        self._vol_value = int(app_data)
        self._engine.set_volume(self._vol_value / 100.0)

    def _toggle_mute(self) -> None:
        self._muted = not self._muted
        self._engine.set_muted(self._muted)
        dpg.configure_item(self._tag_mute_btn,
                           label="\U0001f507" if self._muted else "\U0001f50a")

    # ── Settings toggles ──────────────────────────────────────────────────────

    def _toggle_meter(self) -> None:
        self._meter_enabled = not self._meter_enabled
        for strip in self._slot_meters:
            if strip:
                strip.set_visible(self._meter_enabled)
        for bar in self._slot_corr:
            if bar:
                bar.set_visible(self._meter_enabled and self._corr_enabled)

    def _toggle_lufs(self) -> None:
        self._lufs_enabled = not self._lufs_enabled
        if self._lufs_enabled:
            for idx, t in enumerate(self._tracks):
                if t.get("lufs_curve") is not None:
                    self._draw_lufs_overlay(idx)
        else:
            for idx in range(len(self._tracks)):
                for tag in (f"lufs_line_{idx}", f"lufs_score_{idx}"):
                    if dpg.does_item_exist(tag):
                        dpg.delete_item(tag)

    def _toggle_corr(self) -> None:
        self._corr_enabled = not self._corr_enabled
        for bar in self._slot_corr:
            if bar:
                bar.set_visible(self._meter_enabled and self._corr_enabled)

    def _update_dim_rects(self) -> None:
        """Dim all slots when spectrogram is active; clear when off.
        Active track gets full dim (spectrogram renders on top); inactive tracks get
        a lighter dim so the waveform remains partially visible."""
        for idx in range(4):
            tag = self._slot_dim_rects[idx]
            if tag is None:
                continue
            if not self._spectrogram_enabled or self._spectrogram_fullscreen:
                alpha = 0
            elif idx == self._active:
                alpha = 178   # ~70% — spectrogram renders on top so waveform can be dark
            else:
                alpha = 100   # ~39% — lighter, waveform still readable as context
            try:
                dpg.configure_item(tag, fill=(0, 0, 0, alpha))
            except Exception:
                pass

    def _set_fft_type(self, fft_type: str) -> None:
        """Set FFT display type: 'spectrum', 'spectrogram', or 'off'. Mutually exclusive."""
        was_spectrogram = self._spectrogram_enabled

        self._spectrum_enabled    = (fft_type == "spectrum")
        self._spectrogram_enabled = (fft_type == "spectrogram")

        # If fullscreen was active and we're leaving spectrogram mode, tear it down
        if self._spectrogram_fullscreen and was_spectrogram and not self._spectrogram_enabled:
            self._destroy_fullscreen_spectrogram()

        # If fullscreen is active and we're entering spectrogram mode, build it
        if self._spectrogram_fullscreen and not was_spectrogram and self._spectrogram_enabled:
            self._build_fullscreen_spectrogram()

        for ov in self._slot_spectra:
            if ov:
                ov.set_visible(self._spectrum_enabled)
        for sg in self._slot_spectrograms:
            if sg:
                sg.set_visible(self._spectrogram_enabled and not self._spectrogram_fullscreen)
        self._update_dim_rects()

        # If spectrogram was just turned on, trigger computation for any tracks
        # whose spectrogram hasn't been computed yet (e.g. loaded before enabling).
        if self._spectrogram_enabled and not was_spectrogram:
            self._ensure_spectrograms_computed()

    def _ensure_spectrograms_computed(self) -> None:
        """Launch spectrogram computation for any loaded tracks that don't have it yet.

        Called when spectrogram mode is first enabled so tracks loaded while the
        spectrogram was off still get their textures computed.
        """
        wave_w = max(1, self._track_area_w - METER_W)
        slot_h = max(1, (self._track_area_h - _TRACK_PAD * (MAX_TRACKS - 1)) // MAX_TRACKS)
        for idx, t in enumerate(self._tracks):
            if t.get("spectro_rgba") is None and t.get("wave_raw"):
                threading.Thread(
                    target=self._spectro_thread,
                    args=(idx, t["path"], wave_w, slot_h),
                    daemon=True,
                ).start()

    def _build_fullscreen_spectrogram(self) -> None:
        """Create the fullscreen SpectrogramStrip in a floating DPG window.

        A floating window is used (not a child of tracks_win) because DPG child
        windows always render on top of drawlists added to the same parent regardless
        of insertion order.  A floating window correctly layers on top of everything.

        The window covers wave_w × track_area_h, leaving the meter column visible.
        """
        vw = self._track_area_w
        vh = self._track_area_h
        wave_w = max(1, vw - METER_W)

        # Position: tracks_win starts at y = _MENU_H inside the primary window.
        win_x = 0
        win_y = _MENU_H

        with dpg.theme() as _fs_win_theme:
            with dpg.theme_component(dpg.mvWindowAppItem):
                dpg.add_theme_style(dpg.mvStyleVar_WindowPadding, 0, 0)
                dpg.add_theme_style(dpg.mvStyleVar_ItemSpacing,   0, 0)
                dpg.add_theme_color(dpg.mvThemeCol_WindowBg,      (0, 0, 0, 255))

        dpg.add_window(
            tag="fs_spectro_win",
            pos=(win_x, win_y),
            width=wave_w, height=vh,
            no_title_bar=True, no_resize=True, no_move=True,
            no_scrollbar=True, no_scroll_with_mouse=True,
            no_background=False,
        )
        dpg.bind_item_theme("fs_spectro_win", _fs_win_theme)

        # Invisible click button — added FIRST so drawlist renders on top.
        # Drawlists don't intercept mouse events, so the button beneath still
        # receives all clicks.  Same pattern as slot_click_N buttons.
        with dpg.theme() as _fs_invis:
            with dpg.theme_component(dpg.mvButton):
                dpg.add_theme_color(dpg.mvThemeCol_Button,       (0, 0, 0, 0))
                dpg.add_theme_color(dpg.mvThemeCol_ButtonHovered, (255, 255, 255, 0))
                dpg.add_theme_color(dpg.mvThemeCol_ButtonActive,  (255, 255, 255, 0))
                dpg.add_theme_style(dpg.mvStyleVar_FramePadding,  0, 0)
        dpg.add_button(
            label="", pos=(0, 0), width=wave_w, height=vh,
            callback=self._on_fullscreen_click,
            tag="fs_click_btn", parent="fs_spectro_win",
        )
        dpg.bind_item_theme("fs_click_btn", _fs_invis)

        # Drawlist fills the entire floating window — added AFTER button so it
        # renders on top visually (drawlists pass mouse events through).
        dl = dpg.add_drawlist(
            tag="fs_spectro_dl",
            width=wave_w, height=vh,
            parent="fs_spectro_win",
            pos=(0, 1),
        )

        # SpectrogramStrip
        self._fs_strip = SpectrogramStrip(
            tex_registry=self._tex_reg,
            drawlist_tag=dl,
            width=wave_w,
            height=vh,
            active_color="#E943E1",
            scroll_step=2,
        )
        self._fs_strip.set_visible(True)
        self._fs_strip.set_zoom(self._spectrogram_zoom)

        # Launch fullscreen-height spectrogram computation for the active track.
        # The slot rgba is the wrong height (slot_h vs vh) — passing it to set_data
        # would create a mismatched texture and crash.  Always compute at vh.
        if self._active < len(self._tracks):
            t = self._tracks[self._active]
            if t.get("wave_raw"):
                self._inc_processing()   # fullscreen spectrogram
                threading.Thread(
                    target=self._spectro_fs_thread,
                    args=(self._active, t["path"], wave_w, vh),
                    daemon=True,
                ).start()

        # Playhead line — on top of spectrogram
        dpg.draw_line(
            (0, 0), (0, vh),
            color=(255, 255, 255, 220), thickness=2,
            tag="fs_play_line", parent=dl,
        )

        # Track name text
        self._update_fullscreen_track_name()

        # "x" close label drawn into the drawlist — purely visual
        dpg.draw_text(
            (wave_w - 18, 4), "x", size=13,
            color=(180, 180, 180, 200),
            tag="fs_close_label", parent=dl,
        )

    def _destroy_fullscreen_spectrogram(self) -> None:
        """Tear down the fullscreen floating window and its strip."""
        if self._fs_strip:
            self._fs_strip.delete()
            self._fs_strip = None
        if dpg.does_item_exist("fs_spectro_win"):
            dpg.delete_item("fs_spectro_win")

    def _on_fullscreen_click(self) -> None:
        """Seek on click, or close if top-right corner hit."""
        mx, my = dpg.get_mouse_pos(local=True)
        wave_w = max(1, self._track_area_w - METER_W)
        if 0 <= my < 20 and mx > wave_w - 24 and wave_w > 24:
            self._toggle_spectrogram_fullscreen()
            return
        frac = max(0.0, min(1.0, mx / wave_w))
        self._seek_to(frac * self._max_dur)

    def _update_fullscreen_track_name(self) -> None:
        """Update or create the track name text in the fullscreen overlay."""
        if not self._spectrogram_fullscreen:
            return
        name = ""
        if self._tracks and self._active < len(self._tracks):
            name = os.path.basename(self._tracks[self._active]["path"])
        tag = "fs_spectro_name"
        if dpg.does_item_exist(tag):
            dpg.configure_item(tag, default_value=name)
        elif dpg.does_item_exist("fs_spectro_win"):
            dpg.add_text(
                name, tag=tag, pos=(8, 4),
                color=list(_BTN_FG),
                parent="fs_spectro_win",
            )
            if self._font_bold:
                dpg.bind_item_font(tag, self._font_bold)

    def _toggle_spectrum(self) -> None:
        self._spectrum_enabled = not self._spectrum_enabled
        if self._spectrum_enabled:
            # Mutual exclusion: turn off spectrogram
            self._spectrogram_enabled = False
            for sg in self._slot_spectrograms:
                if sg:
                    sg.set_visible(False)
        for ov in self._slot_spectra:
            if ov:
                ov.set_visible(self._spectrum_enabled)
        self._update_dim_rects()

    def _toggle_spectrogram(self) -> None:
        self._spectrogram_enabled = not self._spectrogram_enabled
        if self._spectrogram_enabled:
            # Mutual exclusion: turn off spectrum bars
            self._spectrum_enabled = False
            for ov in self._slot_spectra:
                if ov:
                    ov.set_visible(False)
        for sg in self._slot_spectrograms:
            if sg:
                sg.set_visible(self._spectrogram_enabled)
        self._update_dim_rects()

    def _toggle_spectrogram_fullscreen(self) -> None:
        self._spectrogram_fullscreen = not self._spectrogram_fullscreen
        if self._spectrogram_fullscreen:
            # Auto-switch to spectrogram mode if not already there
            if not self._spectrogram_enabled:
                self._set_fft_type("spectrogram")
                return   # _set_fft_type calls _build_fullscreen_spectrogram above
            self._build_fullscreen_spectrogram()
        else:
            self._destroy_fullscreen_spectrogram()
            # Restore per-slot spectrogram visibility
            for sg in self._slot_spectrograms:
                if sg:
                    sg.set_visible(self._spectrogram_enabled)

    def _toggle_fft_show(self) -> None:
        self._fft_show_active = not self._fft_show_active
        self._update_dim_rects()

    def _set_fft_size(self, sz: int) -> None:
        self._fft_size = sz
        configure_fft(sz, self._fft_bands)

    def _set_fft_bands(self, nb: int) -> None:
        self._fft_bands = nb
        configure_fft(self._fft_size, nb)
        for ov in self._slot_spectra:
            if ov:
                ov.reset_smooth()

    def _set_spectrogram_zoom(self, factor: float) -> None:
        self._spectrogram_zoom = factor
        for sg in self._slot_spectrograms:
            if sg:
                sg.set_zoom(factor)
        if self._fs_strip:
            self._fs_strip.set_zoom(factor)

    def _toggle_wave_normalize(self) -> None:
        self._wave_normalize = not self._wave_normalize
        self._recalc_wave_scale()
        for i in range(len(self._tracks)):
            self._refresh_track_waveform(i)

    def _toggle_audio_normalize(self) -> None:
        self._audio_normalize = not self._audio_normalize
        self._recalc_audio_gains()

    def _toggle_perf_logging(self) -> None:
        if self._perf.enabled:
            self._perf.disable()
            _log(f"Perf logging stopped: {self._perf.log_path}")
        else:
            path = self._perf.enable(self._perf_log_dir)
            _log(f"Perf logging started: {path}")

    def _toggle_ui_scale(self) -> None:
        self._ui_scale = 2 if self._ui_scale == 1 else 1
        s = float(self._ui_scale)
        dpg.set_global_font_scale(s)

    def _recalc_wave_scale(self) -> bool:
        peak = 1
        for t in self._tracks:
            p = t.get("wave_peak", 0)
            if p > peak:
                peak = p
        changed = (peak != self._wave_global_peak)
        self._wave_global_peak = peak
        return changed

    def _recalc_audio_gains(self) -> None:
        if not self._audio_normalize:
            for t in self._tracks:
                self._engine.set_gain(t["id"], 1.0)
            return
        global_peak = max((t.get("audio_peak", 0.0) for t in self._tracks), default=0.0)
        if global_peak <= 0.0:
            return
        for t in self._tracks:
            tp   = t.get("audio_peak", 0.0)
            gain = (global_peak / tp) if tp > 0.0 else 1.0
            self._engine.set_gain(t["id"], gain)

    # ── Viewport resize ───────────────────────────────────────────────────────

    def _on_viewport_resize(self) -> None:
        vw = dpg.get_viewport_client_width()
        vh = dpg.get_viewport_client_height()
        new_w = max(1, vw)
        new_h = max(1, vh - _MENU_H - _CTRL_H)

        # Skip if nothing changed (DPG fires this callback continuously during drag)
        if new_w == self._track_area_w and new_h == self._track_area_h:
            return

        self._track_area_w = new_w
        self._track_area_h = new_h

        # Resize the tracks container to its new explicit height
        if dpg.does_item_exist(self._tracks_win):
            dpg.configure_item(self._tracks_win, height=self._track_area_h)

        self._rebuild_track_area()
        self._update_ctrl_spacer()

    # ── File open / DnD ───────────────────────────────────────────────────────

    def _open_file_dialog(self) -> None:
        limit = MAX_TRACKS_NULL if self._null_mode else MAX_TRACKS
        if len(self._tracks) >= limit:
            return
        with dpg.file_dialog(
            label="Open audio file(s)",
            callback=self._on_file_dialog_ok,
            width=600, height=400,
            modal=True,
        ):
            for ext in ("wav", "flac", "mp3", "aac", "ogg", "m4a", "aiff", "aif", "opus"):
                dpg.add_file_extension(f".{ext}", color=(150, 220, 150, 255))
            dpg.add_file_extension(".*")

    def _on_file_dialog_ok(self, sender, app_data) -> None:
        selections = app_data.get("selections", {})
        limit = MAX_TRACKS_NULL if self._null_mode else MAX_TRACKS
        for path in selections.values():
            if len(self._tracks) >= limit:
                break
            if os.path.isfile(path):
                self._add_track(path)

    def _on_os_drop(self, paths: list) -> None:
        """Called by win_drop when files are dropped from Explorer."""
        limit = MAX_TRACKS_NULL if self._null_mode else MAX_TRACKS
        for p in paths:
            if len(self._tracks) >= limit:
                break
            if os.path.isfile(p):
                self._add_track(p)

    # ── Key handlers ──────────────────────────────────────────────────────────

    def _on_key_space(self, *_)  -> None: self.toggle_play()
    def _on_key_up(self, *_)    -> None: self._switch_track(-1)
    def _on_key_down(self, *_)  -> None: self._switch_track(+1)
    def _on_key_left(self, *_)  -> None: self._seek_relative(-5.0)
    def _on_key_right(self, *_) -> None: self._seek_relative(+5.0)
    def _on_key_m(self, *_)     -> None: self._toggle_mute()

    def _on_key_ctrl_o(self, *_) -> None:
        if dpg.is_key_down(dpg.mvKey_LControl) or dpg.is_key_down(dpg.mvKey_RControl):
            self._open_file_dialog()

    def _on_key_ctrl_q(self, *_) -> None:
        if dpg.is_key_down(dpg.mvKey_LControl) or dpg.is_key_down(dpg.mvKey_RControl):
            self._on_close()

