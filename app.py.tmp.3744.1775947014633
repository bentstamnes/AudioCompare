    # ── Settings dialog ───────────────────────────────────────────────────────

    def _show_settings(self) -> None:
        if dpg.does_item_exist("settings_modal"):
            return
        if not _HAS_SD:
            self._show_modal_error("sounddevice not available",
                                   "Install sounddevice and numpy.")
            return

        apis    = available_apis()
        devices = available_output_devices()
        api_names = ["Default"] + [a[0] for a in apis]

        _, best_api = best_default_device()
        saved_api   = self._prefs.get("audio_api_name", best_api or "Default")
        saved_dev   = self._prefs.get("audio_device_name", "")

        def dev_list_for(api_name):
            if api_name == "Default":
                return [("System default", None)] + [(n, i) for n, i, _ in devices]
            return [("Default for API", None)] + [
                (n, i) for n, i, a in devices if a == api_name
            ]

        _state = {"api": saved_api,
                  "dev_list": dev_list_for(saved_api),
                  "dev": saved_dev}

        with dpg.window(tag="settings_modal", label="Audio device",
                        modal=True, width=460, height=160,
                        pos=(200, 200), no_resize=True):

            dpg.add_text("Audio API")
            dpg.add_combo(api_names, default_value=saved_api,
                          tag="settings_api", width=380,
                          callback=lambda s, a: _on_api_change(a))

            dpg.add_text("Output device")
            dev_names = [n for n, _ in _state["dev_list"]]
            init_dev  = saved_dev if saved_dev in dev_names else dev_names[0]
            dpg.add_combo(dev_names, default_value=init_dev,
                          tag="settings_dev", width=380)

            with dpg.group(horizontal=True):
                dpg.add_button(label="Cancel",
                               callback=lambda: dpg.delete_item("settings_modal"))
                dpg.add_spacer(width=8)
                dpg.add_button(label="Apply", callback=_on_apply)

        def _on_api_change(api_name):
            _state["api"] = api_name
            _state["dev_list"] = dev_list_for(api_name)
            new_names = [n for n, _ in _state["dev_list"]]
            dpg.configure_item("settings_dev", items=new_names,
                               default_value=new_names[0])

        def _on_apply():
            chosen_name = dpg.get_value("settings_dev")
            chosen_idx  = next(
                (i for n, i in _state["dev_list"] if n == chosen_name), None
            )
            self._prefs["audio_api_name"]    = dpg.get_value("settings_api")
            self._prefs["audio_device_name"] = chosen_name
            self._prefs["audio_device_idx"]  = chosen_idx
            try:
                self._engine.reopen(device=chosen_idx)
            except Exception as exc:
                self._show_modal_error("Device error", str(exc))
                return
            dpg.delete_item("settings_modal")

    # ── Modal helpers ─────────────────────────────────────────────────────────

    def _show_modal_error(self, title: str, message: str) -> None:
        tag = f"err_modal_{abs(hash(title + message)) % 10000}"
        if dpg.does_item_exist(tag):
            return
        with dpg.window(tag=tag, label=title, modal=True,
                        width=400, height=120, pos=(200, 200), no_resize=True):
            dpg.add_text(message, wrap=380)
            dpg.add_spacer(height=8)
            dpg.add_button(label="OK", callback=lambda: dpg.delete_item(tag))

    # ── Prefs ─────────────────────────────────────────────────────────────────

    def _load_prefs(self) -> None:
        try:
            with open(_PREFS_FILE) as f:
                self._prefs = json.load(f)
        except Exception:
            self._prefs = {}

    def _save_prefs(self) -> None:
        try:
            os.makedirs(_PREFS_DIR, exist_ok=True)
            self._prefs["win_width"]        = dpg.get_viewport_width()
            self._prefs["win_height"]       = dpg.get_viewport_height()
            self._prefs["meter_enabled"]    = self._meter_enabled
            self._prefs["corr_enabled"]     = self._corr_enabled
            self._prefs["lufs_enabled"]     = self._lufs_enabled
            self._prefs["spectrum_enabled"]    = self._spectrum_enabled
            self._prefs["spectrogram_enabled"] = self._spectrogram_enabled
            self._prefs.pop("spectrogram_sharper",    None)   # removed — no longer used
            self._prefs.pop("spectrogram_fullscreen", None)   # never persisted — crashes on restore
            self._prefs["fft_size"]            = self._fft_size
            self._prefs["fft_bands"]        = self._fft_bands
            self._prefs["fft_show_active"]  = self._fft_show_active
            self._prefs["wave_normalize"]   = self._wave_normalize
            self._prefs["audio_normalize"]  = self._audio_normalize
            self._prefs["volume"]           = self._vol_value
            self._prefs["muted"]            = self._muted
            with open(_PREFS_FILE, "w") as f:
                json.dump(self._prefs, f)
        except Exception:
            pass

    # ── Close ─────────────────────────────────────────────────────────────────

    def _on_close(self) -> None:
        self._perf.disable()
        self._save_prefs()
        self._engine.close()
        win_drop.unregister_drop_target(self._hwnd)
        dpg.stop_dearpygui()

    # ── Run ───────────────────────────────────────────────────────────────────

    def run(self) -> None:
        dpg.set_exit_callback(self._on_close)
        while dpg.is_dearpygui_running():
            dpg.render_dearpygui_frame()
            if self._tick_ready:
                self._tick()
        dpg.destroy_context()
